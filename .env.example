# Variables de entorno — LocalWebs
# Copiar este archivo a .env y rellenar los valores

# ═══════════════════════════════════════════════════════════
# EMAIL (para formulario de contacto)
# ═══════════════════════════════════════════════════════════
# Servidor SMTP para enviar emails desde el formulario de contacto.
# Recomendado: Resend (https://resend.com) — gratis hasta 3,000 emails/día.
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Destinatario de los emails del formulario de contacto
CONTACT_EMAIL_TO=hola@localwebs.es

# ═══════════════════════════════════════════════════════════
# SEGURIDAD
# ═══════════════════════════════════════════════════════════
# Cadena aleatoria de al menos 32 caracteres para firmar tokens CSRF.
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=cambiar_esto_por_una_cadena_aleatoria_de_64_chars_minimo

# Ventana de tiempo para rate limiting en milisegundos (default: 15 minutos)
RATE_LIMIT_WINDOW=900000

# Máximo de peticiones permitidas por IP en la ventana (default: 3)
RATE_LIMIT_MAX=3

# ═══════════════════════════════════════════════════════════
# reCAPTCHA v3 (Google)
# ═══════════════════════════════════════════════════════════
# Obtener claves en: https://www.google.com/recaptcha/admin
# Tipo: reCAPTCHA v3
RECAPTCHA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PUBLIC_RECAPTCHA_SITE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════
# OPCIONAL: Upstash Redis para rate limiting en edge
# ═══════════════════════════════════════════════════════════
# Si usas Vercel/Netlify con múltiples regiones, el rate limit en memoria
# no funciona bien. Upstash Redis (gratis hasta 10,000 requests/día) soluciona esto.
UPSTASH_REDIS_REST_URL=https://xxx-xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxAQIncxxxxxxx

# ═══════════════════════════════════════════════════════════
# ANALYTICS (solo carga tras consentimiento de cookies)
# ═══════════════════════════════════════════════════════════
# Google Analytics 4 Measurement ID. Se carga solo si el usuario acepta cookies.
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
