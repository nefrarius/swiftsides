---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/layout/Navbar.astro';
import Footer from '@components/layout/Footer.astro';
import CookieBanner from '@components/layout/CookieBanner.astro';
import WhatsAppButton from '@components/layout/WhatsAppButton.astro';
import ScrollToTop from '@components/layout/ScrollToTop.astro';

const team = [
  { name: 'Juan José Ortiz', role: 'Co-Fundador & Developer', initials: 'JO', color: 'bg-primary', linkedin: 'https://www.linkedin.com/in/juan-jos%C3%A9-ortiz-71a2803b3/' },
  { name: 'Imanol Lubiano', role: 'Co-Fundador & Developer', initials: 'IL', color: 'bg-secondary', linkedin: 'https://www.linkedin.com/in/imanol-lubiano-428039279/' },
];

const values = [
  { title: 'Rapidez', desc: 'Entregamos proyectos en tiempo récord sin sacrificar calidad.', icon: 'bolt' },
  { title: 'Transparencia', desc: 'Precios claros, procesos visibles y comunicación constante.', icon: 'eye' },
  { title: 'Creatividad', desc: 'Cada web es única, diseñada para destacar en su sector.', icon: 'sparkles' },
  { title: 'Cercanía', desc: 'Trato personalizado como si fuéramos parte de tu equipo.', icon: 'heart' },
];

const milestones = [
  { year: '2024', title: 'El inicio', desc: 'Juan José e Imanol piensan en cómo ayudar a negocios locales a estar más presentes en la tecnología.' },
  { year: '2024', title: 'Formación', desc: 'Estudian Administración de Sistemas Operativos en Red, programación y ciberseguridad de forma autodidacta.' },
  { year: '2025', title: 'Nace SwiftSite', desc: 'Lanzan SwiftSite con el objetivo de ofrecer webs modernas, sencillas y asequibles a negocios locales.' },
];
---

<BaseLayout 
  title="Nosotros | SwiftSite"
  description="Conoce al equipo de SwiftSite. Dos chicos emprendiendo para llevar tu negocio local al mundo digital."
>
  <Navbar slot="navbar" />
  
  <!-- Hero -->
  <section class="relative py-20 md:py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
            Somos el equipo que <span class="text-primary">tu negocio</span> necesita
          </h1>
          <p class="text-lg text-text/70 leading-relaxed">
            En SwiftSite somos dos chicos emprendiendo que, además de reforzar nuestros conocimientos,
            queremos ayudar a negocios locales a tener una web moderna y sencilla a un buen precio.
          </p>
        </div>
        <div class="relative">
          <svg viewBox="0 0 400 320" class="w-full h-auto" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Team illustration -->
            <rect x="60" y="40" width="280" height="240" rx="16" fill="#13132A" stroke="#6C63FF" stroke-width="2" opacity="0.6"/>
            <circle cx="140" cy="120" r="30" fill="#FF6584" opacity="0.8"/>
            <rect x="110" y="160" width="60" height="80" rx="8" fill="#6C63FF" opacity="0.3"/>
            <circle cx="200" cy="100" r="35" fill="#43CBFF" opacity="0.7"/>
            <rect x="165" y="145" width="70" height="90" rx="8" fill="#43CBFF" opacity="0.2"/>
            <circle cx="270" cy="130" r="28" fill="#6C63FF" opacity="0.8"/>
            <rect x="240" y="170" width="60" height="75" rx="8" fill="#FF6584" opacity="0.2"/>
            <!-- Decorative elements -->
            <circle cx="50" cy="50" r="15" fill="#43CBFF" opacity="0.2"/>
            <circle cx="350" cy="280" r="20" fill="#FF6584" opacity="0.15"/>
            <path d="M30 180 Q50 220 80 200" stroke="#6C63FF" stroke-width="2" stroke-dasharray="4 4" opacity="0.4"/>
            <path d="M340 100 Q360 140 330 160" stroke="#43CBFF" stroke-width="2" stroke-dasharray="4 4" opacity="0.4"/>
            <!-- Table -->
            <rect x="80" y="260" width="240" height="12" rx="6" fill="#6C63FF" opacity="0.3"/>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- Story Sections -->
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-24">
      <div class="scroll-fade-in grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-3xl font-bold text-white mb-4">La idea</h2>
          <p class="text-text/70 leading-relaxed">
            En 2024, Juan José e Imanol pensaron en cómo podían ayudar a negocios locales a estar más
            presentes en la tecnología. Cada vez más restaurantes, peluquerías, bares y tiendas necesitaban
            una web para informar a sus clientes de sus servicios, y querían hacerlo accesible para todos.
          </p>
        </div>
        <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl h-48 flex items-center justify-center">
          <span class="text-6xl font-bold text-primary/30">2024</span>
        </div>
      </div>

      <div class="scroll-fade-in grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="order-2 md:order-1 bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl h-48 flex items-center justify-center">
          <span class="text-6xl font-bold text-secondary/30">+1</span>
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-3xl font-bold text-white mb-4">Formación autodidacta</h2>
          <p class="text-text/70 leading-relaxed">
            Se pusieron a estudiar Administración de Sistemas Operativos en Red por su cuenta para tener
            un buen control de servidores, y más tarde programación y ciberseguridad de forma autodidacta.
            Todo con el objetivo de ofrecer un servicio profesional y seguro.
          </p>
        </div>
      </div>

      <div class="scroll-fade-in grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-3xl font-bold text-white mb-4">Nace SwiftSite</h2>
          <p class="text-text/70 leading-relaxed">
            En 2025 lanzan SwiftSite con una misión clara: ofrecer webs modernas, sencillas y asequibles
            a negocios locales. No solo reforzar sus conocimientos, sino también ayudar a quienes aún no
            tienen presencia online a dar el salto con una web que les represente.
          </p>
        </div>
        <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl h-48 flex items-center justify-center">
          <span class="text-6xl font-bold text-accent/30">2025</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 md:py-24 bg-card/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">Nuestros Valores</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((value) => (
          <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 text-center group hover:border-primary/30 transition">
            <div class="w-16 h-16 mx-auto mb-6 bg-primary/10 rounded-2xl flex items-center justify-center group-hover:scale-110 transition">
              {value.icon === 'bolt' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
              {value.icon === 'eye' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              )}
              {value.icon === 'sparkles' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                </svg>
              )}
              {value.icon === 'heart' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-semibold text-white mb-3">{value.title}</h3>
            <p class="text-text/60 text-sm leading-relaxed">{value.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 text-center">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
            <span class="counter" data-target="48">0</span>h
          </div>
          <p class="text-text/60">Entrega rápida</p>
        </div>
        <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 text-center">
          <div class="text-4xl md:text-5xl font-bold text-secondary mb-2">
            +<span class="counter" data-target="5">0</span>
          </div>
          <p class="text-text/60">Sectores atendidos</p>
        </div>
        <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 text-center">
          <div class="text-4xl md:text-5xl font-bold text-accent mb-2">
            <span class="counter" data-target="100">0</span>%
          </div>
          <p class="text-text/60">Compromiso</p>
        </div>
        <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 text-center">
          <div class="text-4xl md:text-5xl font-bold text-primary mb-2">
            <span class="counter" data-target="2">0</span>
          </div>
          <p class="text-text/60">Fundadores</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 md:py-24 bg-card/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">Nuestro Equipo</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        {team.map((member) => (
          <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 text-center group hover:border-primary/30 transition">
            <div class={`w-20 h-20 mx-auto mb-6 ${member.color} rounded-full flex items-center justify-center text-white text-xl font-bold`}>
              {member.initials}
            </div>
            <h3 class="text-lg font-semibold text-white mb-1">{member.name}</h3>
            <p class="text-text/60 text-sm mb-4">{member.role}</p>
            <div class="flex justify-center gap-3">
              <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="text-text/40 hover:text-primary transition" aria-label={`LinkedIn de ${member.name}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12">Nuestra Historia</h2>
      <div class="relative">
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-primary/20 md:-translate-x-px"></div>
        {milestones.map((m, i) => (
          <div class="relative flex items-start md:items-center mb-12 last:mb-0">
            <div class={`flex-1 ${i % 2 === 0 ? 'md:text-right md:pr-12' : 'md:order-3 md:pl-12'} pl-12 md:pl-0`}>
              <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 inline-block w-full md:w-auto">
                <span class="text-primary font-bold text-lg">{m.year}</span>
                <h3 class="text-white font-semibold mt-1">{m.title}</h3>
                <p class="text-text/60 text-sm mt-2">{m.desc}</p>
              </div>
            </div>
            <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-primary rounded-full border-4 border-dark -translate-x-1.5 md:-translate-x-1.5 mt-2 md:mt-0 z-10"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <CookieBanner slot="scripts" />
  <WhatsAppButton slot="scripts" />
  <ScrollToTop slot="scripts" />
</BaseLayout>

<script>
  // Fade in on scroll
  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('opacity-100', 'translate-y-0');
        entry.target.classList.remove('opacity-0', 'translate-y-8');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.scroll-fade-in').forEach(el => {
    el.classList.add('opacity-0', 'translate-y-8', 'transition', 'duration-700');
    fadeObserver.observe(el);
  });

  // Animated counters
  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const counter = entry.target as HTMLElement;
        const target = parseInt(counter.dataset.target || '0');
        const duration = 2000;
        const start = performance.now();
        
        const update = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          counter.textContent = Math.floor(eased * target).toString();
          if (progress < 1) requestAnimationFrame(update);
        };
        
        requestAnimationFrame(update);
        counterObserver.unobserve(counter);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.counter').forEach(el => counterObserver.observe(el));
</script>
