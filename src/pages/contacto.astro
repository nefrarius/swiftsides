---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/layout/Navbar.astro';
import Footer from '@components/layout/Footer.astro';
import CookieBanner from '@components/layout/CookieBanner.astro';
import WhatsAppButton from '@components/layout/WhatsAppButton.astro';
import ScrollToTop from '@components/layout/ScrollToTop.astro';
import ContactForm from '@components/forms/ContactForm.astro';
---

<BaseLayout 
  title="Contacto | SwiftSite"
  description="Contacta con SwiftSite para crear o mejorar la web de tu negocio local. Respuesta en menos de 24 horas."
>
  <Navbar slot="navbar" />
  
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Left Column: Info -->
        <div class="space-y-8">
          <div>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Hablemos de tu proyecto</h1>
            <p class="text-lg text-text/70">
              Cuéntanos qué necesitas y te responderemos en menos de 24 horas con un presupuesto sin compromiso.
            </p>
          </div>

          <!-- Contact Info Cards -->
          <div class="space-y-4">
            <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 flex items-start gap-4">
              <div class="bg-primary/20 p-3 rounded-xl shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1">Email</h3>
                <a     href="mailto:contacto@swiftsite.es" class="text-text/70 hover:text-primary transition">contacto@swiftsite.es</a>
              </div>
            </div>

            <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 flex items-start gap-4">
              <div class="bg-secondary/20 p-3 rounded-xl shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1">Teléfono</h3>
                <a href="tel:+34600123456" class="text-text/70 hover:text-primary transition">+34 600 123 456</a>
              </div>
            </div>

            <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 flex items-start gap-4">
              <div class="bg-accent/20 p-3 rounded-xl shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1">Ubicación</h3>
                <p class="text-text/70">Valladolid, España</p>
              </div>
            </div>

            <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 flex items-start gap-4">
              <div class="bg-primary/20 p-3 rounded-xl shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1">Horario</h3>
                <p class="text-text/70">Lunes a Viernes: 16:00 - 20:30</p>
              </div>
            </div>
          </div>

          <!-- Social Links -->
          <div>
            <h3 class="font-semibold text-white mb-4">Síguenos</h3>
            <div class="flex gap-4">
              <a href="#" class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-xl p-3 text-text/70 hover:text-primary hover:border-primary/50 transition" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
              <a href="#" class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-xl p-3 text-text/70 hover:text-primary hover:border-primary/50 transition" aria-label="LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              </a>
              <a href="#" class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-xl p-3 text-text/70 hover:text-primary hover:border-primary/50 transition" aria-label="Twitter">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Illustration -->
          <div class="hidden lg:block">
            <svg viewBox="0 0 400 300" class="w-full h-auto opacity-60" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="50" y="80" width="300" height="200" rx="12" fill="#13132A" stroke="#6C63FF" stroke-width="2"/>
              <rect x="70" y="100" width="260" height="140" rx="8" fill="#0D0D1A" stroke="#6C63FF" stroke-width="1" stroke-opacity="0.3"/>
              <circle cx="100" cy="130" r="15" fill="#FF6584" opacity="0.8"/>
              <rect x="130" y="120" width="180" height="8" rx="4" fill="#6C63FF" opacity="0.5"/>
              <rect x="130" y="136" width="140" height="8" rx="4" fill="#43CBFF" opacity="0.4"/>
              <rect x="80" y="170" width="100" height="50" rx="8" fill="#6C63FF" opacity="0.15" stroke="#6C63FF" stroke-width="1"/>
              <rect x="200" y="170" width="110" height="50" rx="8" fill="#FF6584" opacity="0.15" stroke="#FF6584" stroke-width="1"/>
              <path d="M180 280 L220 280 L210 250 L190 250 Z" fill="#13132A" stroke="#6C63FF" stroke-width="2"/>
              <rect x="120" y="280" width="160" height="8" rx="4" fill="#6C63FF" opacity="0.3"/>
              <circle cx="320" cy="60" r="20" fill="#43CBFF" opacity="0.2"/>
              <circle cx="60" cy="200" r="12" fill="#FF6584" opacity="0.2"/>
              <path d="M40 100 Q20 150 50 180" stroke="#6C63FF" stroke-width="2" stroke-dasharray="4 4" opacity="0.4"/>
              <path d="M360 120 Q380 170 350 200" stroke="#43CBFF" stroke-width="2" stroke-dasharray="4 4" opacity="0.4"/>
            </svg>
          </div>
        </div>

        <!-- Right Column: Form -->
        <div class="bg-card/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 md:p-10">
          <h2 class="text-2xl font-bold text-white mb-6">Envíanos un mensaje</h2>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
  <CookieBanner slot="scripts" />
  <WhatsAppButton slot="scripts" />
  <ScrollToTop slot="scripts" />
</BaseLayout>
