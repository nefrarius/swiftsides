---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/layout/Navbar.astro';
import Footer from '@components/layout/Footer.astro';
import CookieBanner from '@components/layout/CookieBanner.astro';
import WhatsAppButton from '@components/layout/WhatsAppButton.astro';
import ScrollToTop from '@components/layout/ScrollToTop.astro';

import Hero from '@components/home/Hero.astro';
import SocialProof from '@components/home/SocialProof.astro';
import ServicesOverview from '@components/home/ServicesOverview.astro';
import HowItWorks from '@components/home/HowItWorks.astro';
import FeaturedPortfolio from '@components/home/FeaturedPortfolio.astro';
import Testimonials from '@components/home/Testimonials.astro';
import PricingPreview from '@components/home/PricingPreview.astro';
import FAQ from '@components/home/FAQ.astro';
import CTAFinal from '@components/home/CTAFinal.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SwiftSite",
  "description": "Diseñamos, desarrollamos y gestionamos páginas web para negocios locales.",
  "url": "https://swiftsite.es",
  "areaServed": "España",
  "serviceType": "Diseño y desarrollo web",
  "priceRange": "€€"
};
---

<BaseLayout
  title="SwiftSite - Diseño Web para Negocios Locales"
  description="Tu negocio local, online y sin límites"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <Navbar slot="navbar" />

  <Hero />
  <SocialProof />
  <ServicesOverview />
  <HowItWorks />
  <FeaturedPortfolio />
  <Testimonials />
  <PricingPreview />
  <FAQ />
  <CTAFinal />

  <Footer slot="footer" />
  <CookieBanner slot="scripts" />
  <WhatsAppButton slot="scripts" />
  <ScrollToTop slot="scripts" />
</BaseLayout>
