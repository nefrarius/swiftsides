---
export interface Props {
  class?: string;
  padding?: 'none' | 'sm' | 'md' | 'lg';
  hoverGlow?: boolean;
}

const {
  class: className = '',
  padding = 'md',
  hoverGlow = false,
} = Astro.props;

const paddingClasses = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const classes = [
  'bg-[#13132A]/80 backdrop-blur-xl border border-white/10 rounded-2xl',
  paddingClasses[padding],
  hoverGlow ? 'transition-shadow duration-300 hover:shadow-[0_0_30px_-5px_rgba(108,99,255,0.3)]' : '',
  className,
].join(' ');
---

<div class={classes}>
  <slot />
</div>