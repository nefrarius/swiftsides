---
import { testimonials } from '@data/testimonials';

const nonce = Astro.locals.nonce || '';
---

<section id="testimonios" class="py-24 bg-card/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">Lo que dicen nuestros clientes</h2>
      <p class="text-text/70 max-w-xl mx-auto">Negocios locales que ya han dado el salto digital.</p>
    </div>

    <div id="testimonials-slider" class="relative overflow-hidden">
      <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory pb-6" id="testimonials-track" style="scrollbar-width: none; -ms-overflow-style: none;">
        {testimonials.map((t) => (
          <div class="snap-center shrink-0 w-[85vw] md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 testimonial-card">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center text-primary font-heading font-bold">
                {t.initials}
              </div>
              <div>
                <h4 class="font-heading font-bold text-white">{t.name}</h4>
                <p class="text-sm text-text/60">{t.type}</p>
              </div>
            </div>
            <div class="flex gap-1 mb-4">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg class={`w-4 h-4 ${i < t.rating ? 'text-yellow-400' : 'text-white/10'}`} viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p class="text-text/80 leading-relaxed italic">"{t.text}"</p>
          </div>
        ))}
      </div>

      <!-- Dots -->
      <div class="flex justify-center gap-2 mt-4">
        {testimonials.map((_, i) => (
          <button class="testimonial-dot w-2 h-2 rounded-full bg-white/20 hover:bg-white/40 transition-colors" data-index={i} aria-label={`Testimonio ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!isReducedMotion) {
    gsap.from('.testimonial-card', {
      y: 40,
      opacity: 0,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#testimonios',
        start: 'top 80%',
      }
    });
  }
</script>

<script is:inline nonce={nonce}>
  (function() {
    const track = document.getElementById('testimonials-track');
    const dots = document.querySelectorAll('.testimonial-dot');
    const cards = track.children;
    let current = 0;
    let interval;
    const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function scrollToIndex(index) {
      if (index >= cards.length) index = 0;
      const card = cards[index];
      if (!card) return;
      const scrollLeft = card.offsetLeft - track.offsetLeft - (track.clientWidth - card.clientWidth) / 2;
      track.scrollTo({ left: scrollLeft, behavior: isReducedMotion ? 'auto' : 'smooth' });
      dots.forEach((d, i) => {
        d.classList.toggle('bg-primary', i === index);
        d.classList.toggle('bg-white/20', i !== index);
      });
      current = index;
    }

    function start() {
      if (interval) clearInterval(interval);
      interval = setInterval(() => {
        scrollToIndex(current + 1);
      }, 5000);
    }

    function stop() { if (interval) clearInterval(interval); }

    track.addEventListener('mouseenter', stop);
    track.addEventListener('mouseleave', start);

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        scrollToIndex(i);
        stop();
        start();
      });
    });

    scrollToIndex(0);
    start();
  })();
</script>
