---
import { services } from '@data/services';

const selectedServices = [
  services.find(s => s.id === 'diseno-web'),
  services.find(s => s.id === 'mantenimiento'),
  services.find(s => s.id === 'seo-local'),
].filter((s): s is typeof services[number] => !!s);
---

<section id="servicios" class="py-24 bg-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-white mb-4">Nuestros servicios</h2>
      <p class="text-text/70 max-w-xl mx-auto">Todo lo que necesitas para tener una web profesional y mantenerla a punto.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {selectedServices.map((service) => (
        <div class="service-card group bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 hover:border-accent/30 hover:bg-white/[0.07] hover:-translate-y-1 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-6 group-hover:shadow-[0_0_20px_rgba(67,203,255,0.3)] group-hover:scale-110 transition-all duration-300">
            <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              {service.id === 'diseno-web' && (
                <>
                  <path d="M12 19l7-7 3 3-7 7-3-3z"></path>
                  <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"></path>
                  <path d="M2 2l7.586 7.586"></path>
                  <circle cx="11" cy="11" r="2"></circle>
                </>
              )}
              {service.id === 'mantenimiento' && (
                <>
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
                </>
              )}
              {service.id === 'seo-local' && (
                <>
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </>
              )}
            </svg>
          </div>
          <h3 class="font-heading text-xl font-bold text-white mb-3">{service.title}</h3>
          <p class="text-text/70 mb-6 leading-relaxed">{service.description}</p>
          <ul class="space-y-2 mb-8">
            {service.features.slice(0, 3).map(f => (
              <li class="flex items-start gap-2 text-sm text-text/80">
                <span class="w-1.5 h-1.5 rounded-full bg-accent mt-1.5 shrink-0"></span>
                {f}
              </li>
            ))}
          </ul>
          <a href={`/servicios#${service.id}`} class="inline-flex items-center text-primary font-medium hover:text-accent transition-colors">
            Saber más
            <svg class="w-4 h-4 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const cards = document.querySelectorAll('.service-card');
  const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!isReducedMotion) {
    gsap.from(cards, {
      y: 60,
      opacity: 0,
      duration: 0.8,
      stagger: 0.2,
      ease: 'power3.out',
      scrollTrigger: {
        trigger: '#servicios',
        start: 'top 80%',
      }
    });
  }
</script>
