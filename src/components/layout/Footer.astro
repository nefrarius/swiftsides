---
import NewsletterForm from '@components/forms/NewsletterForm.astro';

const currentYear = new Date().getFullYear();

const mainLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/pricing', label: 'Precios' },
  { href: '/nosotros', label: 'Nosotros' },
  { href: '/contacto', label: 'Contacto' },
];

const serviceLinks = [
  { href: '/servicios#diseno-web', label: 'Diseño Web' },
  { href: '/servicios#seo-local', label: 'SEO Local' },
  { href: '/servicios#ecommerce', label: 'E-commerce' },
  { href: '/servicios#mantenimiento', label: 'Mantenimiento' },
];

const legalLinks = [
  { href: '/legal/privacidad', label: 'Política de privacidad' },
  { href: '/legal/cookies', label: 'Política de cookies' },
];
---

<footer class="relative border-t border-white/10 bg-[#0D0D1A]/90 backdrop-blur-xl mt-auto">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Column 1: Logo + Description -->
      <div class="space-y-4">
        <a href="/" class="inline-flex items-center gap-2" aria-label="SwiftSite Inicio">
          <svg width="34" height="34" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="6" y="2" width="30" height="32" rx="8" fill="#0F0F0F"/>
            <rect x="10" y="5" width="22" height="22" rx="5" fill="#1a1a2e"/>
            <path d="M17 11 Q22 9 25 11" fill="none" stroke="#00E5FF" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M25 11 Q28 9 31 11" fill="none" stroke="#00E5FF" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="21" cy="16" r="3" fill="#00E5FF"/>
            <circle cx="22" cy="15" r="1.2" fill="#fff" opacity="0.6"/>
            <path d="M26 16 Q28 14 29 16" fill="none" stroke="#00E5FF" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="26" y1="16" x2="29" y2="16" stroke="#00E5FF" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M20 22 Q23 24 29 21" fill="none" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round"/>
            <circle cx="30" cy="21" r="1.5" fill="#FF6B9D" opacity="0.7"/>
            <rect x="12" y="16" width="4" height="8" rx="2" fill="#0F0F0F"/>
            <rect x="28" y="16" width="4" height="8" rx="2" fill="#0F0F0F"/>
            <rect x="19" y="32" width="6" height="3" rx="1.5" fill="#0F0F0F"/>
          </svg>
          <span class="text-lg font-bold text-[#E8E8F0]" style="font-family: 'Plus Jakarta Sans', sans-serif;">SwiftSite</span>
        </a>
        <p class="text-sm text-[#E8E8F0]/70 leading-relaxed">
          Diseñamos y desarrollamos páginas web profesionales para negocios locales. Hosting y dominio incluidos en todos los planes.
        </p>
        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs text-emerald-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          <span>Sitio protegido con HTTPS</span>
        </div>
      </div>

      <!-- Column 2: Main Links -->
      <div>
        <h3 class="text-sm font-semibold text-[#E8E8F0] uppercase tracking-wider mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Navegación</h3>
        <ul class="space-y-3">
          {mainLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-[#E8E8F0]/70 hover:text-[#43CBFF] transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#43CBFF] rounded">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Services -->
      <div>
        <h3 class="text-sm font-semibold text-[#E8E8F0] uppercase tracking-wider mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Servicios</h3>
        <ul class="space-y-3">
          {serviceLinks.map(link => (
            <li>
              <a href={link.href} class="text-sm text-[#E8E8F0]/70 hover:text-[#43CBFF] transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#43CBFF] rounded">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Newsletter + Legal + Social -->
      <div class="space-y-6">
        <div>
          <h3 class="text-sm font-semibold text-[#E8E8F0] uppercase tracking-wider mb-4" style="font-family: 'Plus Jakarta Sans', sans-serif;">Newsletter</h3>
          <NewsletterForm />
        </div>

        <div>
          <h3 class="text-sm font-semibold text-[#E8E8F0] uppercase tracking-wider mb-3" style="font-family: 'Plus Jakarta Sans', sans-serif;">Legal</h3>
          <ul class="space-y-2">
            {legalLinks.map(link => (
              <li>
                <a href={link.href} class="text-xs text-[#E8E8F0]/50 hover:text-[#E8E8F0]/80 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#43CBFF] rounded">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="flex items-center gap-4">
          <a href="#" class="text-[#E8E8F0]/60 hover:text-[#43CBFF] hover:scale-110 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#43CBFF] rounded" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
          <a href="#" class="text-[#E8E8F0]/60 hover:text-[#43CBFF] hover:scale-110 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#43CBFF] rounded" aria-label="Twitter">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
          </a>
          <a href="#" class="text-[#E8E8F0]/60 hover:text-[#43CBFF] hover:scale-110 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#43CBFF] rounded" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[#E8E8F0]/40">
        © {currentYear} SwiftSite. Todos los derechos reservados.
      </p>
      <p class="text-xs text-[#E8E8F0]/40">
        Diseñado y desarrollado con <span class="text-[#FF6584]" aria-hidden="true">♥</span> en España
      </p>
    </div>
  </div>
</footer>