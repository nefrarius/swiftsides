<form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 w-full max-w-md" novalidate>
  <div class="flex-1 relative">
    <input
      type="email"
      id="newsletter-email"
      name="email"
      required
      maxlength="254"
      placeholder="tu@email.com"
      class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white placeholder-text/40 focus:outline-none focus:border-primary transition"
    />
    <p id="newsletter-field-error" class="absolute -bottom-6 left-0 text-xs text-red-400 hidden"></p>
  </div>

  <button
    type="submit"
    id="newsletter-btn"
    class="px-6 py-2 rounded-lg bg-primary text-white font-semibold hover:bg-primary/90 transition whitespace-nowrap disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center gap-2"
  >
    <span id="newsletter-btn-text">Suscribirse</span>
    <span id="newsletter-btn-spinner" class="hidden">
      <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </span>
  </button>
</form>

{/* Success message */}
<div id="newsletter-success" class="hidden rounded-lg bg-green-500/10 border border-green-500/20 p-3 text-green-400 text-sm text-center w-full max-w-md">
  ¡Gracias por suscribirte!
</div>

{/* Error message */}
<div id="newsletter-error-box" class="hidden rounded-lg bg-red-500/10 border border-red-500/20 p-3 text-red-400 text-sm text-center w-full max-w-md">
  <span id="newsletter-error-text"></span>
</div>

<script>
  (function () {
    const form = document.getElementById('newsletter-form');
    const emailInput = document.getElementById('newsletter-email');
    const btn = document.getElementById('newsletter-btn');
    const btnText = document.getElementById('newsletter-btn-text');
    const btnSpinner = document.getElementById('newsletter-btn-spinner');
    const fieldError = document.getElementById('newsletter-field-error');
    const successBox = document.getElementById('newsletter-success');
    const errorBox = document.getElementById('newsletter-error-box');
    const errorBoxText = document.getElementById('newsletter-error-text');

    const EMAIL_REGEX = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/;

    function setStatus(isValid, text) {
      if (!isValid && text) {
        emailInput.classList.remove('border-white/10', 'border-green-500');
        emailInput.classList.add('border-red-500');
        fieldError.classList.remove('hidden');
        fieldError.textContent = text;
      } else {
        emailInput.classList.remove('border-red-500', 'border-white/10');
        emailInput.classList.add('border-green-500');
        fieldError.classList.add('hidden');
        fieldError.textContent = '';
      }
    }

    emailInput.addEventListener('blur', () => {
      const val = emailInput.value.trim();
      if (!val) {
        setStatus(false, 'El correo es obligatorio.');
        return;
      }
      if (!EMAIL_REGEX.test(val)) {
        setStatus(false, 'Correo electrónico inválido.');
        return;
      }
      setStatus(true, '');
    });

    function showLoading(loading) {
      btn.disabled = loading;
      if (loading) {
        btnText.classList.add('hidden');
        btnSpinner.classList.remove('hidden');
      } else {
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const val = emailInput.value.trim();
      if (!val || !EMAIL_REGEX.test(val)) {
        setStatus(false, 'Introduce un correo válido.');
        return;
      }

      showLoading(true);
      successBox.classList.add('hidden');
      errorBox.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();

        if (res.ok && data.success) {
          form.reset();
          emailInput.classList.remove('border-green-500', 'border-red-500');
          emailInput.classList.add('border-white/10');
          successBox.classList.remove('hidden');
          setTimeout(() => successBox.classList.add('hidden'), 5000);
        } else {
          // Security: use textContent, never innerHTML
          errorBoxText.textContent = data.message || 'No se pudo completar la suscripción.';
          errorBox.classList.remove('hidden');
        }
      } catch (err) {
        errorBoxText.textContent = 'Error de red. Inténtalo de nuevo.';
        errorBox.classList.remove('hidden');
      } finally {
        showLoading(false);
      }
    });
  })();
</script>
