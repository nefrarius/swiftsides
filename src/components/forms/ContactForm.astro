---
import { generateCsrfToken } from '../../utils/csrf';

// ============================================================
// Security: generate or reuse CSRF token and set it as a cookie.
// The API will compare the hidden form field against this cookie.
// ============================================================
let csrfToken = Astro.cookies.get('csrf_token')?.value;
if (!csrfToken) {
  csrfToken = generateCsrfToken();
  Astro.cookies.set('csrf_token', csrfToken, {
    httpOnly: false,
    sameSite: 'strict',
    path: '/',
    secure: import.meta.env.PROD,
  });
}

// Public site key for reCAPTCHA v3 (client-side)
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY || '';
---

<form id="contact-form" class="space-y-6" novalidate>
  {/* ============================================================
      Security: honeypot field. Hidden from humans via CSS;
      bots will fill it and the API will silently reject them.
  ============================================================ */}
  <div style="position:absolute;left:-9999px;" aria-hidden="true">
    <input type="text" name="website" id="website" tabindex="-1" autocomplete="off" />
  </div>

  {/* Security: CSRF token synced with the cookie */}
  <input type="hidden" name="csrf_token" value={csrfToken} />

  {/* Security: reCAPTCHA v3 invisible token */}
  <input type="hidden" name="recaptcha_token" id="recaptcha-token" />

  <div>
    <label for="nombre" class="block text-sm font-medium text-text/80 mb-1">Nombre completo *</label>
    <input
      type="text"
      id="nombre"
      name="nombre"
      required
      maxlength="100"
      class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white placeholder-text/40 focus:outline-none focus:border-primary transition"
      placeholder="Tu nombre"
    />
    <p id="error-nombre" class="mt-1 text-sm text-red-400 hidden"></p>
  </div>

  <div>
    <label for="email" class="block text-sm font-medium text-text/80 mb-1">Email *</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      maxlength="254"
      class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white placeholder-text/40 focus:outline-none focus:border-primary transition"
      placeholder="tu@email.com"
    />
    <p id="error-email" class="mt-1 text-sm text-red-400 hidden"></p>
  </div>

  <div>
    <label for="telefono" class="block text-sm font-medium text-text/80 mb-1">Teléfono</label>
    <input
      type="tel"
      id="telefono"
      name="telefono"
      maxlength="20"
      class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white placeholder-text/40 focus:outline-none focus:border-primary transition"
      placeholder="+34 600 000 000"
    />
    <p id="error-telefono" class="mt-1 text-sm text-red-400 hidden"></p>
  </div>

  <div>
    <label for="tipo_negocio" class="block text-sm font-medium text-text/80 mb-1">Tipo de negocio</label>
    <select
      id="tipo_negocio"
      name="tipo_negocio"
      class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:border-primary transition"
    >
      <option value="" disabled selected>Selecciona uno...</option>
      <option value="restaurante">Restaurante</option>
      <option value="peluqueria">Peluquería</option>
      <option value="tienda-tech">Tienda Tech</option>
      <option value="clinica">Clínica</option>
      <option value="gym">Gimnasio</option>
      <option value="otros">Otros</option>
    </select>
    <p id="error-tipo_negocio" class="mt-1 text-sm text-red-400 hidden"></p>
  </div>

  <div>
    <label for="plan_interes" class="block text-sm font-medium text-text/80 mb-1">Plan de interés</label>
    <select
      id="plan_interes"
      name="plan_interes"
      class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white focus:outline-none focus:border-primary transition"
    >
      <option value="" disabled selected>Selecciona uno...</option>
      <option value="basico">Básico</option>
      <option value="profesional">Profesional</option>
      <option value="premium">Premium</option>
      <option value="no-se">No estoy seguro</option>
    </select>
    <p id="error-plan_interes" class="mt-1 text-sm text-red-400 hidden"></p>
  </div>

  <div>
    <label for="mensaje" class="block text-sm font-medium text-text/80 mb-1">Mensaje *</label>
    <textarea
      id="mensaje"
      name="mensaje"
      required
      maxlength="2000"
      rows="4"
      class="w-full px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-white placeholder-text/40 focus:outline-none focus:border-primary transition resize-y"
      placeholder="Cuéntanos sobre tu proyecto..."
    ></textarea>
    <p id="error-mensaje" class="mt-1 text-sm text-red-400 hidden"></p>
  </div>

  <div class="flex items-start gap-3">
    <input
      type="checkbox"
      id="rgpd"
      name="rgpd"
      required
      class="mt-1 h-4 w-4 rounded border-white/20 bg-white/5 text-primary focus:ring-primary"
    />
    <label for="rgpd" class="text-sm text-text/70">
      Acepto la <a href="/legal/privacidad" class="text-primary hover:underline">política de privacidad</a> *
    </label>
  </div>
  <p id="error-rgpd" class="text-sm text-red-400 hidden"></p>

  <button
    type="submit"
    id="submit-btn"
    class="w-full px-6 py-3 rounded-lg bg-primary text-white font-semibold hover:bg-primary/90 transition flex items-center justify-center gap-2 disabled:opacity-60 disabled:cursor-not-allowed"
  >
    <span id="btn-text">Enviar mensaje</span>
    <span id="btn-spinner" class="hidden">
      <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
    </span>
  </button>

  {/* Success message (hidden by default) */}
  <div id="form-success" class="hidden rounded-lg bg-green-500/10 border border-green-500/20 p-4 text-green-400 text-center">
    <p class="font-semibold">¡Mensaje enviado con éxito!</p>
    <p class="text-sm mt-1">Te contactaremos lo antes posible.</p>
  </div>

  {/* Error message (hidden by default) */}
  <div id="form-error" class="hidden rounded-lg bg-red-500/10 border border-red-500/20 p-4 text-red-400 text-center">
    <p class="font-semibold" id="error-title">Ha ocurrido un error</p>
    <p class="text-sm mt-1" id="error-desc">Inténtalo de nuevo más tarde.</p>
  </div>
</form>

{/* Confetti canvas overlay for success animation */}
<canvas id="confetti-canvas" class="fixed inset-0 pointer-events-none z-50 hidden"></canvas>

{/* Load reCAPTCHA v3 script only when key is present */}
{recaptchaSiteKey && (
  <script src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`} async defer></script>
)}

<script define:vars={{ recaptchaSiteKey }}>
  (function () {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnSpinner = document.getElementById('btn-spinner');
    const successMsg = document.getElementById('form-success');
    const errorMsg = document.getElementById('form-error');
    const errorTitle = document.getElementById('error-title');
    const errorDesc = document.getElementById('error-desc');
    const confettiCanvas = document.getElementById('confetti-canvas');

    // Validation patterns (must match backend)
    const NAME_REGEX = /^[a-zA-ZÀ-ÿ\s'-]{2,100}$/;
    const EMAIL_REGEX = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/;
    const PHONE_REGEX = /^[\d\s\+\-\(\)]{9,20}$/;

    /**
     * Updates field border color and error text.
     * Security: uses textContent, NEVER innerHTML.
     */
    function setFieldStatus(field, isValid, errorId, errorText) {
      const errorEl = document.getElementById(errorId);
      if (!errorEl) return;
      if (isValid) {
        field.classList.remove('border-red-500', 'border-white/10');
        field.classList.add('border-green-500');
        errorEl.classList.add('hidden');
        errorEl.textContent = '';
      } else {
        field.classList.remove('border-green-500', 'border-white/10');
        field.classList.add('border-red-500');
        errorEl.classList.remove('hidden');
        errorEl.textContent = errorText || '';
      }
    }

    function validateNombre() {
      const el = document.getElementById('nombre');
      const val = el.value.trim();
      if (!val) {
        setFieldStatus(el, false, 'error-nombre', 'El nombre es obligatorio.');
        return false;
      }
      if (!NAME_REGEX.test(val)) {
        setFieldStatus(el, false, 'error-nombre', 'Nombre inválido. Usa solo letras, espacios y apóstrofes (2-100 caracteres).');
        return false;
      }
      setFieldStatus(el, true, 'error-nombre', '');
      return true;
    }

    function validateEmail() {
      const el = document.getElementById('email');
      const val = el.value.trim();
      if (!val) {
        setFieldStatus(el, false, 'error-email', 'El correo es obligatorio.');
        return false;
      }
      if (!EMAIL_REGEX.test(val)) {
        setFieldStatus(el, false, 'error-email', 'Correo electrónico inválido.');
        return false;
      }
      setFieldStatus(el, true, 'error-email', '');
      return true;
    }

    function validateTelefono() {
      const el = document.getElementById('telefono');
      const val = el.value.trim();
      if (!val) {
        setFieldStatus(el, true, 'error-telefono', '');
        return true;
      }
      if (!PHONE_REGEX.test(val)) {
        setFieldStatus(el, false, 'error-telefono', 'Teléfono inválido.');
        return false;
      }
      setFieldStatus(el, true, 'error-telefono', '');
      return true;
    }

    function validateMensaje() {
      const el = document.getElementById('mensaje');
      const val = el.value.trim();
      if (!val) {
        setFieldStatus(el, false, 'error-mensaje', 'El mensaje es obligatorio.');
        return false;
      }
      if (val.length < 10) {
        setFieldStatus(el, false, 'error-mensaje', 'El mensaje debe tener al menos 10 caracteres.');
        return false;
      }
      if (val.length > 2000) {
        setFieldStatus(el, false, 'error-mensaje', 'El mensaje no puede superar los 2000 caracteres.');
        return false;
      }
      setFieldStatus(el, true, 'error-mensaje', '');
      return true;
    }

    function validateRgpd() {
      const el = document.getElementById('rgpd');
      const errorEl = document.getElementById('error-rgpd');
      if (!el.checked) {
        errorEl.classList.remove('hidden');
        errorEl.textContent = 'Debes aceptar la política de privacidad.';
        return false;
      }
      errorEl.classList.add('hidden');
      errorEl.textContent = '';
      return true;
    }

    // Real-time validation on blur
    document.getElementById('nombre').addEventListener('blur', validateNombre);
    document.getElementById('email').addEventListener('blur', validateEmail);
    document.getElementById('telefono').addEventListener('blur', validateTelefono);
    document.getElementById('mensaje').addEventListener('blur', validateMensaje);
    document.getElementById('rgpd').addEventListener('change', validateRgpd);

    function showLoading(loading) {
      submitBtn.disabled = loading;
      if (loading) {
        btnText.classList.add('hidden');
        btnSpinner.classList.remove('hidden');
      } else {
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
      }
    }

    function showSuccess() {
      form.reset();
      successMsg.classList.remove('hidden');
      errorMsg.classList.add('hidden');

      // Reset visual borders
      ['nombre', 'email', 'telefono', 'mensaje'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) {
          el.classList.remove('border-red-500', 'border-green-500');
          el.classList.add('border-white/10');
        }
      });

      runConfetti();
      setTimeout(() => {
        successMsg.classList.add('hidden');
      }, 6000);
    }

    function showError(title, description) {
      errorMsg.classList.remove('hidden');
      successMsg.classList.add('hidden');
      // Security: always use textContent, never innerHTML
      errorTitle.textContent = title || 'Ha ocurrido un error';
      errorDesc.textContent = description || 'Inténtalo de nuevo más tarde.';
    }

    /**
     * Simple canvas confetti burst.
     * No external libraries required.
     */
    function runConfetti() {
      confettiCanvas.classList.remove('hidden');
      const ctx = confettiCanvas.getContext('2d');
      confettiCanvas.width = window.innerWidth;
      confettiCanvas.height = window.innerHeight;

      const particles = [];
      const colors = ['#ef4444', '#22c55e', '#3b82f6', '#eab308', '#a855f7', '#06b6d4'];

      for (let i = 0; i < 120; i++) {
        particles.push({
          x: window.innerWidth / 2,
          y: window.innerHeight / 2,
          vx: (Math.random() - 0.5) * 14,
          vy: (Math.random() - 0.5) * 14 - 4,
          size: Math.random() * 6 + 2,
          color: colors[Math.floor(Math.random() * colors.length)],
          life: 1,
        });
      }

      function animate() {
        ctx.clearRect(0, 0, confettiCanvas.width, confettiCanvas.height);
        let alive = false;
        particles.forEach((p) => {
          if (p.life <= 0) return;
          alive = true;
          p.x += p.vx;
          p.y += p.vy;
          p.vy += 0.25; // gravity
          p.life -= 0.015;
          ctx.globalAlpha = p.life;
          ctx.fillStyle = p.color;
          ctx.fillRect(p.x, p.y, p.size, p.size);
        });
        if (alive) {
          requestAnimationFrame(animate);
        } else {
          confettiCanvas.classList.add('hidden');
        }
      }
      animate();
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Run all client-side validators before sending
      const vNombre = validateNombre();
      const vEmail = validateEmail();
      const vTelefono = validateTelefono();
      const vMensaje = validateMensaje();
      const vRgpd = validateRgpd();
      if (!vNombre || !vEmail || !vTelefono || !vMensaje || !vRgpd) {
        return;
      }

      showLoading(true);

      try {
        // Obtain reCAPTCHA v3 token if configured
        let recaptchaToken = '';
        if (recaptchaSiteKey) {
          if (typeof grecaptcha === 'undefined') {
            showError('Error de seguridad', 'El verificador de seguridad aún no ha cargado. Espera unos segundos e inténtalo de nuevo.');
            showLoading(false);
            return;
          }
          recaptchaToken = await new Promise((resolve, reject) => {
            grecaptcha.ready(() => {
              grecaptcha.execute(recaptchaSiteKey, { action: 'submit' })
                .then((token) => resolve(token))
                .catch((err) => reject(err));
            });
          });
        }
        document.getElementById('recaptcha-token').value = recaptchaToken;

        const formData = new FormData(form);
        const res = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const data = await res.json();

        if (res.ok && data.success) {
          showSuccess();
        } else {
          if (data.errors) {
            const firstKey = Object.keys(data.errors)[0];
            const firstError = data.errors[firstKey];
            showError('Error en el formulario', firstError);
          } else {
            showError('Error', data.message || 'No se pudo enviar el mensaje.');
          }
        }
      } catch (err) {
        showError('Error de red', 'Comprueba tu conexión e inténtalo de nuevo.');
      } finally {
        showLoading(false);
      }
    });
  })();
</script>
